# --- Python virtual environments ---
venv/
.venv/
.venv312/

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Logs ---
*.log

# --- Local databases (never commit ingestion DBs) ---
*.sqlite
*.db

# --- App/runtime output ---
output/
var/cache/

# --- Audio artifacts (Blendz outputs) ---
*.mp3
*.wav
*.m4a
*.aac

# --- Temporary concat / source audio ---
source_audio.*
blendz_*.txt

# --- Ingestion artifacts (CRITICAL) ---
# Hash-based or chunk files generated during ingestion
[a-f0-9][a-f0-9][a-f0-9][a-f0-9]*
*.json
*.npy
*.pkl

# --- Transcripts / embeddings / intermediate data ---
transcripts/
embeddings/
chunks/
ingestion_output/

# --- OS ---
.DS_Store
workspace/
episode_manifest*.jsonl

.env
processed_chunks/

audio/temp/
# Ignore generated audio files but NOT source code
audio/*.mp3
audio/*.wav
audio/*.m4a
audio/*.aac
audio/temp/

# ✅ allow cluster + theme data for production
!podpal/semantic/clusters.json
!podpal/semantic/themes.json
*.json

# ✅ allow cluster + theme data for production
!podpal/semantic/clusters.json
!podpal/semantic/themes.json

# ✅ allow critical production data
!data/
!data/audio_catalog.json
!data/transcription_jobs/*.json
!data/selected_episodes/*.json
